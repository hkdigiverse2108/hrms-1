# HRMS Configuration Template

# Frontend Port
PORT=3535

# Backend Port
BACKEND_PORT=8000

# MongoDB Connection String
# Example: mongodb+srv://user:pass@cluster.mongodb.net/dbname
MONGO_URL=mongodb+srv://...

# Database Security (Optional)
# Set to 'false' in production if you have valid certificates
ALLOW_INVALID_CERTS=true

# CORS Allowed Origins (comma-separated)
# For production, set to your domain(s):
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Defaults to http://localhost:3535,http://127.0.0.1:3535 for local dev
ALLOWED_ORIGINS=http://localhost:3535,http://127.0.0.1:3535
