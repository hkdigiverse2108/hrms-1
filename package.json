{
  "name": "hrms-desktop",
  "version": "1.0.7",
  "description": "HRMS Desktop Application Container",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "pack:win": "electron-builder --dir --win",
    "pack:mac": "electron-builder --dir --mac",
    "publish-desktop": "node scripts/publish-release.js"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.hrms.app",
    "productName": "HRMS",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "backend/dist/backend.exe",
          "to": "backend/backend.exe"
        },
        {
          "from": "backend/dist/watchdog.exe",
          "to": "backend/watchdog.exe"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": true,
      "include": "installer.nsh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.business",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extraResources": [
        {
          "from": "backend/dist/backend",
          "to": "backend/backend"
        }
      ]
    },
    "dmg": {
      "title": "HRMS ${version}",
      "icon": "frontend/public/icon-light-32x32.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      ".env.server"
    ],
    "extraResources": [
      {
        "from": "frontend/.next/standalone",
        "to": "app/frontend/.next/standalone"
      },
      {
        "from": "frontend/.next/static",
        "to": "app/frontend/.next/standalone/.next/static"
      },
      {
        "from": "frontend/public",
        "to": "app/frontend/.next/standalone/public"
      },
      {
        "from": "frontend/.next/static",
        "to": "app/frontend/.next/standalone/frontend/.next/static"
      },
      {
        "from": "frontend/public",
        "to": "app/frontend/.next/standalone/frontend/public"
      }
    ]
  }
}